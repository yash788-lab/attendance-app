{
  "functions": {
    "api/**/*.py": {
      "includeFiles": [
        "templates/**/*",
        "static/**/*",
        "routes/**/*",
        "models/**/*",
        "services/**/*",
        "utils/**/*"
      ]
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/api/index.py" }
  ]
}
